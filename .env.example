# PS1 AI Player — Environment Variables
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# .env is listed in .gitignore and will NOT be committed.

# OpenAI API key (required for GPT-4o Vision agent and LLM-enhanced GDD)
OPENAI_API_KEY=sk-your-key-here

# Virtual display number for Xvfb (optional, default: 99)
# DISPLAY_NUM=99

# DuckStation AppImage path (optional, default: ./duckstation/DuckStation.AppImage)
# DUCKSTATION_PATH=./duckstation/DuckStation.AppImage
